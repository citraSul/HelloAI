# hirelens-web — copy to `.env` and fill in values (see docs/local-development.md).
#
# DATABASE_URL — put this ONLY in `.env` (not in `.env.local`).
# Prisma CLI (`npm run db:push`, `prisma generate`) reads `hirelens-web/.env` by default.
# Next.js loads `.env` then `.env.local`; defining DATABASE_URL in both makes `.env.local` win.
#
# PostgreSQL URL shape:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=hirelens
# If you share a DB with Spring/JPA, prefer ?schema=hirelens so Prisma does not touch other tables.
#
# Replace __REPLACE_ME__ with your real Postgres password (no angle brackets in the actual URL).
DATABASE_URL="postgresql://postgres:__REPLACE_ME__@127.0.0.1:5432/sitra?schema=hirelens"

# mock = built-in mocks for match/tailor/impact (no Flask required). Default if unset.
# real = requires FLASK_BASE_URL + HIRELENS_INTERNAL_API_KEY; pipeline calls fail loudly if misconfigured.
APP_MODE=mock

# Real mode checklist (local validation):
#   1. APP_MODE=real
#   2. FLASK_BASE_URL — same origin your Flask app listens on (no trailing slash)
#   3. HIRELENS_INTERNAL_API_KEY — must match the key configured in Flask for internal routes
#   4. Start Flask before Score match / Tailor / Impact
#   5. Open /diagnostics — "Pipeline active" should be OK
#
# Optional: log structured match/tailor/impact/decision summaries to the Next.js server console (local only).
# HIRELENS_PIPELINE_DEBUG=1

NEXT_PUBLIC_APP_NAME="HireLens"

# Must match Flask listen address + PORT (Python app defaults to PORT=8765 in app.py).
FLASK_BASE_URL="http://127.0.0.1:8765"
HIRELENS_INTERNAL_API_KEY="replace_with_same_secret_as_flask"

# Optional — Flask HTTP client (Node server routes only; see docs/FLASK_PIPELINE_CONNECTIVITY.md)
# FLASK_FETCH_TIMEOUT_MS=45000
# FLASK_FETCH_MAX_RETRIES=2
# FLASK_STARTUP_HEALTH_TIMEOUT_MS=5000

# Set to 1 in Next.js Docker images so loopback FLASK_BASE_URL triggers startup + diagnostics warnings.
# RUNNING_IN_DOCKER=1

NEXT_PUBLIC_API_URL="http://127.0.0.1:8080"

# Adzuna Jobs API (used by fetchAdzunaJobs / ingest pipeline). Register at https://developer.adzuna.com/
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""

# Shared secret for POST /api/jobs/ingest — send header X-Cron-Secret: <value> or Authorization: Bearer <value>
CRON_SECRET=""
