# PostgreSQL (required for Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/hirelens?schema=public"

NEXT_PUBLIC_APP_NAME="HireLens"

# Python Flask (resume-job-matcher) — when BOTH are set, API routes use the real pipeline instead of mocks.
# Generate a long random string and use the SAME value in Flask HIRELENS_INTERNAL_API_KEY.
FLASK_BASE_URL="http://127.0.0.1:8080"
HIRELENS_INTERNAL_API_KEY="replace_with_same_secret_as_flask"

# Optional: public URL if the browser ever calls Flask directly (not required for server-side integration).
NEXT_PUBLIC_API_URL="http://127.0.0.1:8080"
