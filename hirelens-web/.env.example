# Default local dev: SQLite (no Docker). Copy to .env.local
DATABASE_URL="file:./dev.db"

# Production / team Postgres (use docker-compose.yml in repo root, or Neon, etc.):
# DATABASE_URL="postgresql://user:password@localhost:5432/hirelens?schema=public"
# If you switch DATABASE_URL to Postgres, set prisma/schema.prisma datasource provider to "postgresql".

NEXT_PUBLIC_APP_NAME="HireLens"

# Python Flask — when BOTH FLASK_BASE_URL and HIRELENS_INTERNAL_API_KEY are set, match/tailor/impact use real pipeline.
FLASK_BASE_URL="http://127.0.0.1:8080"
HIRELENS_INTERNAL_API_KEY="replace_with_same_secret_as_flask"

NEXT_PUBLIC_API_URL="http://127.0.0.1:8080"
