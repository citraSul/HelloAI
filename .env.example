# Default in app.py is 8765 — align hirelens-web FLASK_BASE_URL port with this value.
PORT=8765
APP_BASE_URL=http://127.0.0.1:8765

# Same secret as hirelens-web HIRELENS_INTERNAL_API_KEY — enables POST /api/internal/v2/pipeline and /api/internal/evaluate-impact
HIRELENS_INTERNAL_API_KEY=replace_with_long_random_secret
APP_DB_PATH=app.db
SECRET_KEY=replace_with_long_random_secret
SUPPORT_EMAIL=support@yourdomain.com

# Public job feed (Remote OK API — not LinkedIn). Cron hits POST /api/cron/fetch-feed every 30 min.
CRON_SECRET=replace_with_random_long_secret
# Optional: in-process scheduler (use only with gunicorn --workers 1)
ENABLE_JOB_FEED_SCHEDULER=0
JOB_FEED_INTERVAL_MINUTES=30

# Stripe (required for paid plan checkout)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PRICE_ID_PRO=price_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
